# going-bridge worker — ingesta señales de Going como nodos + briefing ejecutivo.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Embeddings de las señales.
OPENAI_API_KEY=
# Briefing ejecutivo (Claude).
ANTHROPIC_API_KEY=
# Repo de Going en GitHub, formato "owner/repo".
GOING_GITHUB_REPO=
# Token de GitHub (para repo privado / alertas de seguridad / rate limit alto). Opcional.
GITHUB_TOKEN=
# Workspace de MyCortex donde aterrizan las señales de Going (el de Rubén).
BRIDGE_WORKSPACE_ID=
BRIDGE_USER_ID=
# Ventana de señales a traer (días).
BRIDGE_LOOKBACK_DAYS=14
