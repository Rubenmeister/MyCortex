; Local .npmrc para apps/mobile cuando EAS Build sube ESTE dir como
; standalone. Sin este archivo, npm hereda el `.npmrc` del monorepo root
; que tiene flags de pnpm (`shamefully-hoist`, `strict-peer-dependencies`,
; `auto-install-peers`) que npm no reconoce y emite warnings, y posiblemente
; rompen el resolver en condiciones específicas de EAS Build.
;
; Estas líneas son las equivalentes/no-op para npm.
legacy-peer-deps=true
fund=false
audit=false
