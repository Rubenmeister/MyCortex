auto-install-peers=true
strict-peer-dependencies=false
# node-linker: usamos el AISLADO por defecto de pnpm (symlinks), NO hoisted.
#
# Por qué NO hoisted: el `node_modules` plano de hoisted mezcla dos majors de
# React en el monorepo (móvil=18 de Expo, web=19 de Next 15) y rompe el
# `next build` del web al pre-renderizar /404 (`pages/_error`): "useContext null"
# / "Objects are not valid as a React child". El aislado le da a cada app su
# propia copia de React y el web compila. (Diagnóstico: docs/WEB-BUILD-BLOCKER.md.)
#
# El móvil NO se ve afectado: apps/mobile es STANDALONE (sin deps workspace:*,
# con su propio package-lock.json) y EAS lo compila con npm, sin este .npmrc.
# Para el dev local de Metro contra el monorepo, ver apps/mobile/metro.config.js.
node-linker=isolated
