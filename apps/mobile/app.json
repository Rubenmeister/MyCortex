{
  "expo": {
    "name": "MyCortex",
    "slug": "mycortex",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "mycortex",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mycortex.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "MyCortex usa el micrófono para capturar tus notas de voz."
      }
    },
    "android": {
      "package": "com.mycortex.app",
      "permissions": ["RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "MyCortex usa el micrófono para capturar tus notas de voz."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
