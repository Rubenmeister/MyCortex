{
  "expo": {
    "name": "MyCortex",
    "slug": "mycortex",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "mycortex",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mycortex.app"
    },
    "android": {
      "package": "com.mycortex.app"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
