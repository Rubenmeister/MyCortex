auto-install-peers=true
strict-peer-dependencies=false
# node-linker=hoisted: node_modules plano (estilo npm) en vez del aislado de pnpm.
# Necesario para React Native / Metro (apps/mobile): el resolver de Metro no
# entiende la estructura simbólica de pnpm y no encuentra deps transitivas como
# @babel/runtime. Hoisted las deja accesibles. No rompe los builds de api/workers
# (sus Dockerfiles instalan por --filter igual).
node-linker=hoisted
